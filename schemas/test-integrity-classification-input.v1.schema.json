{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/test-integrity-classification-input.v1.schema.json",
  "title": "Rigor test-integrity classification input v1",
  "description": "Human-reported classification of the signals a test-integrity event fired. classifiedBy is a recorded declaration, not attested identity, and never satisfies any control. The recording command copies event linkage from the referenced event artifact rather than trusting these fields, and rejects verdicts naming signals the event did not fire.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "eventArtifactId",
    "verdicts",
    "classifiedBy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "rigor.test-integrity-classification-input.v1"
    },
    "taskId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "eventArtifactId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "verdicts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signalId", "verdict"],
        "properties": {
          "signalId": {
            "enum": ["TI-05", "TI-06", "TI-07", "TI-08", "TI-09"]
          },
          "verdict": {
            "enum": ["true-positive", "false-positive", "uncertain"]
          },
          "note": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "classifiedBy": { "const": "human" }
  }
}
