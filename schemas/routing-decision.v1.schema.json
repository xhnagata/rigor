{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/routing-decision.v1.schema.json",
  "title": "Rigor routing decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "taskId",
    "preflightArtifactId",
    "preflightHash",
    "routingInputHash",
    "modelProfilesHash",
    "purpose",
    "requiredCapabilityClass",
    "eligibleCandidates",
    "excludedCandidates",
    "selection",
    "controls",
    "budget",
    "assessment",
    "status"
  ],
  "properties": {
    "schemaVersion": { "const": "rigor.routing-decision.v1" },
    "mode": { "const": "dry-run" },
    "taskId": { "type": "string", "minLength": 1 },
    "preflightArtifactId": { "type": "string", "minLength": 1 },
    "preflightHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "routingInputHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "modelProfilesHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "purpose": { "$ref": "#/$defs/purpose" },
    "requiredCapabilityClass": { "$ref": "#/$defs/capability" },
    "eligibleCandidates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "excludedCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidateId", "reasonCode"],
        "properties": {
          "candidateId": { "type": "string", "minLength": 1 },
          "reasonCode": {
            "enum": [
              "DISABLED",
              "PURPOSE_UNSUPPORTED",
              "EXTERNAL_TRANSMISSION_DENIED",
              "INSUFFICIENT_CAPABILITY",
              "BUDGET_EXCEEDED",
              "UNAVAILABLE",
              "INCOMPATIBLE"
            ]
          }
        }
      }
    },
    "selection": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "candidateId",
            "provider",
            "capabilityClass",
            "relativeCost"
          ],
          "properties": {
            "candidateId": { "type": "string", "minLength": 1 },
            "provider": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "capabilityClass": { "$ref": "#/$defs/capability" },
            "relativeCost": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "externalTransmission",
        "requireHumanApproval",
        "requireIndependentReview"
      ],
      "properties": {
        "externalTransmission": { "enum": ["allowed", "denied"] },
        "requireHumanApproval": { "type": "boolean" },
        "requireIndependentReview": { "type": "boolean" }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "maxDurationMs", "maxRelativeCost"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "maxDurationMs": { "type": "integer", "minimum": 1000 },
        "maxRelativeCost": { "type": "integer", "minimum": 1 }
      }
    },
    "availabilityReportHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputSchemaVersion", "confidence", "evidenceCount"],
      "properties": {
        "inputSchemaVersion": {
          "enum": ["rigor.routing-input.v1", "rigor.routing-input.v2"]
        },
        "confidence": { "enum": ["low", "medium", "high"] },
        "evidenceCount": { "type": "integer", "minimum": 0, "maximum": 20 }
      }
    },
    "status": { "enum": ["selected", "unroutable", "requires-review"] }
  },
  "$defs": {
    "capability": {
      "enum": ["economy", "standard", "premium", "frontier"]
    },
    "purpose": {
      "enum": [
        "implementation",
        "consultation",
        "review",
        "adversarial-review",
        "rescue"
      ]
    }
  }
}
