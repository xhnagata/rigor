{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/test-integrity-promotion.v1.schema.json",
  "title": "Rigor inert test-integrity promotion proposal v1",
  "description": "Append-on-create proposal only. status is proposed and approvalEffect is none; activation and replay linkage are deliberately excluded from proposalDigest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactId",
    "createdAt",
    "taskId",
    "policyHash",
    "schemaBindings",
    "signals",
    "approval",
    "proposalDigest",
    "criteria",
    "status",
    "approvalEffect"
  ],
  "properties": {
    "schemaVersion": { "const": "rigor.test-integrity-promotion.v1" },
    "artifactId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "createdAt": { "type": "string", "format": "date-time" },
    "taskId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "policyHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "schemaBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "classification", "promotion", "replay"],
      "properties": {
        "event": { "const": "rigor.test-integrity-event.v1" },
        "classification": { "const": "rigor.test-integrity-classification.v1" },
        "promotion": { "const": "rigor.test-integrity-promotion.v1" },
        "replay": { "const": "rigor.test-integrity-replay.v1" }
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/signal" }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declaredBy", "declaration", "note", "identityAttested"],
      "properties": {
        "declaredBy": { "const": "human" },
        "declaration": { "const": "approved-for-proposal" },
        "note": { "type": "string", "minLength": 1, "maxLength": 500 },
        "identityAttested": { "const": false }
      }
    },
    "proposalDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stop", "review", "advisory"],
      "properties": {
        "stop": { "$ref": "#/$defs/criterion" },
        "review": { "$ref": "#/$defs/criterion" },
        "advisory": { "$ref": "#/$defs/criterion" }
      }
    },
    "status": { "const": "proposed" },
    "approvalEffect": { "const": "none" }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 300 },
        "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumEvaluated",
        "minimumHumanClassifiedFired",
        "maximumFalseDiscoveryProportion"
      ],
      "properties": {
        "minimumEvaluated": { "type": "integer", "minimum": 0 },
        "minimumHumanClassifiedFired": { "type": "integer", "minimum": 0 },
        "maximumFalseDiscoveryProportion": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signalId",
        "detector",
        "evaluatedCandidateSet",
        "requestedEffect",
        "evidence",
        "stratum",
        "rollbackConditions"
      ],
      "properties": {
        "signalId": { "enum": ["TI-05", "TI-06", "TI-07", "TI-08", "TI-09"] },
        "detector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1, "maxLength": 64 },
            "version": { "type": "string", "minLength": 1, "maxLength": 32 }
          }
        },
        "evaluatedCandidateSet": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "configurationDigest"],
          "properties": {
            "version": { "type": "string", "minLength": 1, "maxLength": 64 },
            "configurationDigest": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        },
        "requestedEffect": { "enum": ["stop", "review", "advisory"] },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["events", "classifications"],
          "properties": {
            "events": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1000,
              "items": { "$ref": "#/$defs/evidenceRef" }
            },
            "classifications": {
              "type": "array",
              "maxItems": 1000,
              "items": { "$ref": "#/$defs/evidenceRef" }
            }
          }
        },
        "stratum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["evaluated", "fired", "humanClassified"],
          "properties": {
            "evaluated": { "type": "integer", "minimum": 0 },
            "fired": { "type": "integer", "minimum": 0 },
            "humanClassified": {
              "type": "object",
              "additionalProperties": false,
              "required": ["truePositive", "falsePositive", "uncertain"],
              "properties": {
                "truePositive": { "type": "integer", "minimum": 0 },
                "falsePositive": { "type": "integer", "minimum": 0 },
                "uncertain": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "rollbackConditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "metric",
              "operator",
              "threshold",
              "minimumClassifiedFired"
            ],
            "properties": {
              "metric": {
                "enum": ["false-discovery-proportion", "review-coverage"]
              },
              "operator": { "enum": ["greater-than", "less-than"] },
              "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
              "minimumClassifiedFired": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
