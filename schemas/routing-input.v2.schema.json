{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/routing-input.v2.schema.json",
  "title": "Rigor routing input v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "purpose",
    "signals",
    "assessment",
    "budget"
  ],
  "properties": {
    "schemaVersion": { "const": "rigor.routing-input.v2" },
    "taskId": { "type": "string", "minLength": 1 },
    "purpose": { "$ref": "#/$defs/purpose" },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "complexity",
        "ambiguity",
        "novelty",
        "verificationStrength"
      ],
      "properties": {
        "complexity": { "$ref": "#/$defs/level" },
        "ambiguity": { "$ref": "#/$defs/level" },
        "novelty": { "$ref": "#/$defs/level" },
        "verificationStrength": {
          "enum": ["weak", "moderate", "strong"]
        }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "evidence"],
      "properties": {
        "confidence": { "enum": ["low", "medium", "high"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "observation"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "observation": {
                "type": "string",
                "minLength": 1,
                "maxLength": 10000
              }
            }
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "maxDurationMs", "maxRelativeCost"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 20 },
        "maxDurationMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 86400000
        },
        "maxRelativeCost": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    }
  },
  "$defs": {
    "level": { "enum": ["low", "medium", "high", "critical"] },
    "purpose": {
      "enum": [
        "implementation",
        "consultation",
        "review",
        "adversarial-review",
        "rescue"
      ]
    }
  }
}
