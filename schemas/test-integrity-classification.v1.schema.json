{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/test-integrity-classification.v1.schema.json",
  "title": "Rigor test-integrity classification v1",
  "description": "Recorded human classification of a test-integrity event's fired signals, stored beside the event. Event linkage (taskId, eventArtifactId) is copied from the event artifact, not trusted from input. classifiedBy is a recorded declaration, not attested identity, and satisfies no control.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactId",
    "taskId",
    "createdAt",
    "eventArtifactId",
    "classifiedBy",
    "verdicts"
  ],
  "properties": {
    "schemaVersion": { "const": "rigor.test-integrity-classification.v1" },
    "artifactId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "taskId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "eventArtifactId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "classifiedBy": { "const": "human" },
    "verdicts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signalId", "verdict", "note"],
        "properties": {
          "signalId": {
            "enum": ["TI-05", "TI-06", "TI-07", "TI-08", "TI-09"]
          },
          "verdict": {
            "enum": ["true-positive", "false-positive", "uncertain"]
          },
          "note": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "minLength": 1, "maxLength": 200 }
            ]
          }
        }
      }
    }
  }
}
