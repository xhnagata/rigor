{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/artifacts.v1.schema.json",
  "title": "Rigor v1 evidence artifacts",
  "type": "object",
  "required": ["schemaVersion", "artifactId", "taskId", "createdAt"],
  "properties": {
    "schemaVersion": {
      "enum": [
        "rigor.preflight.v1",
        "rigor.contract.v1",
        "rigor.verification.v1",
        "rigor.escalation.v1",
        "rigor.escalation-decision.v1",
        "rigor.review.v1",
        "rigor.routing-plan.v1",
        "rigor.attempt-session.v1",
        "rigor.attempt.v1",
        "rigor.consultation-session.v1",
        "rigor.consultation.v1",
        "rigor.consultation.v2",
        "rigor.outcome.v1",
        "rigor.calibration-proposal.v1"
      ]
    },
    "artifactId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "schemaVersion": { "const": "rigor.preflight.v1" } }
      },
      "then": {
        "required": [
          "policyHash",
          "intentHash",
          "git",
          "plannedPaths",
          "riskTier",
          "externalTransmission",
          "protectedPaths",
          "requireHumanApproval",
          "stopConditions",
          "reasons"
        ]
      }
    },
    {
      "if": {
        "properties": { "schemaVersion": { "const": "rigor.contract.v1" } }
      },
      "then": {
        "required": [
          "preflightArtifactId",
          "preflightHash",
          "riskTier",
          "externalTransmission",
          "acceptanceCriteria",
          "allowedPaths",
          "constraints",
          "requiredChecks",
          "stopConditions"
        ]
      }
    },
    {
      "if": {
        "properties": { "schemaVersion": { "const": "rigor.verification.v1" } }
      },
      "then": {
        "required": [
          "contractArtifactId",
          "policyHash",
          "treeHash",
          "changedPaths",
          "scopeViolations",
          "checks",
          "status"
        ]
      }
    },
    {
      "if": {
        "properties": { "schemaVersion": { "const": "rigor.review.v1" } }
      },
      "then": {
        "required": [
          "contractArtifactId",
          "verificationArtifactId",
          "riskTier",
          "externalTransmission",
          "verificationStatus"
        ]
      }
    },
    {
      "if": {
        "properties": { "schemaVersion": { "const": "rigor.routing-plan.v1" } }
      },
      "then": {
        "required": [
          "preflightArtifactId",
          "preflightHash",
          "routingInputHash",
          "modelProfilesHash",
          "contractArtifactId",
          "contractHash",
          "policyHash",
          "plannedHead",
          "selection",
          "controls",
          "budget",
          "status"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": { "const": "rigor.attempt-session.v1" }
        }
      },
      "then": {
        "required": [
          "sequence",
          "routingPlanArtifactId",
          "routingPlanHash",
          "contractArtifactId",
          "contractHash",
          "selection",
          "purpose",
          "budget",
          "executionIdentityStatus",
          "beforeHead",
          "beforeTreeHash",
          "changedPathsBefore"
        ]
      }
    },
    {
      "if": {
        "properties": { "schemaVersion": { "const": "rigor.attempt.v1" } }
      },
      "then": {
        "required": [
          "sessionArtifactId",
          "sessionHash",
          "routingPlanArtifactId",
          "routingPlanHash",
          "contractArtifactId",
          "contractHash",
          "sequence",
          "provider",
          "capabilityClass",
          "purpose",
          "startedAt",
          "completedAt",
          "durationMs",
          "executionIdentityStatus",
          "status",
          "beforeHead",
          "afterHead",
          "beforeTreeHash",
          "afterTreeHash",
          "changedPathsBefore",
          "changedPaths",
          "scopeViolations"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": { "const": "rigor.consultation-session.v1" }
        }
      },
      "then": {
        "required": [
          "preflightArtifactId",
          "preflightHash",
          "provider",
          "mode",
          "requestedDecision",
          "transmissionDecision",
          "beforeHead",
          "beforeTreeHash",
          "changedPathsBefore"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": { "const": "rigor.consultation.v1" }
        }
      },
      "then": {
        "required": [
          "sessionArtifactId",
          "sessionHash",
          "provider",
          "mode",
          "requestedDecision",
          "transmissionDecision",
          "beforeTreeHash",
          "afterTreeHash",
          "beforeHead",
          "afterHead",
          "changedPathsBefore",
          "changedPathsAfter",
          "usageStatus",
          "status",
          "outcome",
          "findingCount",
          "requiredActions"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": { "const": "rigor.consultation.v2" }
        }
      },
      "then": {
        "required": [
          "sessionArtifactId",
          "sessionHash",
          "provider",
          "mode",
          "requestedDecision",
          "transmissionDecision",
          "beforeTreeHash",
          "afterTreeHash",
          "beforeHead",
          "afterHead",
          "changedPathsBefore",
          "changedPathsAfter",
          "usageStatus",
          "modelStatus",
          "reasoningEffortStatus",
          "status",
          "outcome",
          "findingCount",
          "findings",
          "requiredActions"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": { "const": "rigor.outcome.v1" }
        }
      },
      "then": {
        "required": [
          "decision",
          "acceptedWithoutModelCodeChanges",
          "humanCorrectionMinutes",
          "escalationCount",
          "retryCount",
          "reviewFindings",
          "revertStatus",
          "escapedDefectStatus",
          "executionIdentityStatus",
          "usage",
          "notes"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": { "const": "rigor.calibration-proposal.v1" }
        }
      },
      "then": {
        "required": [
          "target",
          "summary",
          "evidence",
          "proposedChange",
          "expectedTradeOffs",
          "rollbackCriteria",
          "status",
          "approvalEffect",
          "provenance"
        ]
      }
    }
  ]
}
