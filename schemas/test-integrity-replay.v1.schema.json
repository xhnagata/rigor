{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xhnagata/rigor/schemas/test-integrity-replay.v1.schema.json",
  "title": "Rigor test-integrity replay report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactId",
    "taskId",
    "createdAt",
    "proposalArtifactId",
    "proposalDigest",
    "evidenceRootDigest",
    "replayDigest",
    "signals"
  ],
  "properties": {
    "schemaVersion": { "const": "rigor.test-integrity-replay.v1" },
    "artifactId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "taskId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "proposalArtifactId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "proposalDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "evidenceRootDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "replayDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signalId",
          "requestedEffect",
          "detector",
          "candidateSetVersion",
          "evaluated",
          "fired",
          "wouldFire"
        ],
        "properties": {
          "signalId": { "enum": ["TI-05", "TI-06", "TI-07", "TI-08", "TI-09"] },
          "requestedEffect": { "enum": ["stop", "review", "advisory"] },
          "detector": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 64 },
              "version": { "type": "string", "minLength": 1, "maxLength": 32 }
            }
          },
          "candidateSetVersion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "evaluated": { "type": "integer", "minimum": 0 },
          "fired": { "type": "integer", "minimum": 0 },
          "wouldFire": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
